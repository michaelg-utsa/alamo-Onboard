# ============================================================
# AlamoOnboard environment configuration
# Copy this file to .env and fill in the REQUIRED values.
# ============================================================

# ----------------------------------------------------------
# LLM endpoint (REQUIRED for full conversational answers)
# ----------------------------------------------------------
# Base URL for the OpenAI-compatible chat completions endpoint.
# Example: https://api.openai.com/v1  or a local vLLM server.
ALAMO_LLM_BASE_URL=https://your-openai-compatible-endpoint/v1

# API key for the LLM endpoint above.
# Falls back to OPENAI_API_KEY if this is not set.
# If neither is set, the app runs in demo mode (rule-based retrieval only).
ALAMO_LLM_API_KEY=your-api-key-here

# ----------------------------------------------------------
# LLM model (optional — change to match your endpoint)
# ----------------------------------------------------------
ALAMO_LLM_MODEL=llama-3.3-70b-instruct-awq

# ----------------------------------------------------------
# Embedding model (optional — do not change unless you
# also re-run the SA Utilities embedding pipeline with the
# same model, as the FAISS index must match)
# ----------------------------------------------------------
ALAMO_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
ALAMO_EMBED_DIM=384

# ----------------------------------------------------------
# Demo mode (optional)
# ----------------------------------------------------------
# Set to "1" to force rule-based demo mode even if an API key is present.
# Useful for offline demonstrations.
ALAMO_DEMO_MODE=0

# ----------------------------------------------------------
# Retrieval (optional)
# ----------------------------------------------------------
# Number of passages returned per knowledge-base query.
ALAMO_TOP_K=5
